        options: [
          { emoji: "✅", text: "할 일을 나누고 제출일까지의 계획을 미리 세운다.", type: "J" },
          { emoji: "🌊", text: "우선 아이디어를 떠올리며 상황에 맞게 진행한다.", type: "P" }
        ]
      },
      {
        emoji: "🎪",
