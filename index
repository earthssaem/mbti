<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="학교생활 상황으로 알아보는 깜찍한 MBTI 테스트" />
  <title>학교생활로 알아보는 MBTI 🎒✨</title>
  <style>
    :root {
      --bg1: #fff4fb;
      --bg2: #eef7ff;
      --card: rgba(255, 255, 255, 0.9);
      --text: #3f3952;
      --muted: #746e88;
      --pink: #ff7eb6;
      --purple: #9a7cff;
      --blue: #6eb7ff;
      --yellow: #ffd76e;
      --green: #75d8b0;
      --shadow: 0 18px 45px rgba(95, 76, 150, 0.16);
      --radius: 28px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Pretendard", "Noto Sans KR", "Apple SD Gothic Neo", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 10% 15%, rgba(255, 126, 182, 0.24), transparent 25%),
        radial-gradient(circle at 90% 20%, rgba(110, 183, 255, 0.25), transparent 28%),
        radial-gradient(circle at 80% 85%, rgba(255, 215, 110, 0.22), transparent 25%),
        linear-gradient(135deg, var(--bg1), var(--bg2));
      overflow-x: hidden;
    }

    button {
      font: inherit;
    }

    .floating-emoji {
      position: fixed;
      z-index: 0;
      opacity: 0.55;
      pointer-events: none;
      animation: float 6s ease-in-out infinite;
      filter: drop-shadow(0 6px 8px rgba(92, 76, 130, 0.12));
    }

    .e1 { top: 8%; left: 5%; font-size: 34px; }
    .e2 { top: 16%; right: 7%; font-size: 40px; animation-delay: 1s; }
    .e3 { bottom: 12%; left: 8%; font-size: 38px; animation-delay: 2s; }
    .e4 { bottom: 8%; right: 6%; font-size: 42px; animation-delay: 3s; }
    .e5 { top: 48%; left: 2%; font-size: 28px; animation-delay: 0.5s; }
    .e6 { top: 55%; right: 2%; font-size: 30px; animation-delay: 1.5s; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(-3deg); }
      50% { transform: translateY(-14px) rotate(4deg); }
    }

    .app {
      position: relative;
      z-index: 1;
      width: min(920px, calc(100% - 28px));
      margin: 0 auto;
      padding: 34px 0 52px;
    }

    .screen {
      display: none;
      animation: popIn 0.45s ease;
    }

    .screen.active {
      display: block;
    }

    @keyframes popIn {
      from { opacity: 0; transform: translateY(12px) scale(0.985); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .hero,
    .quiz-card,
    .result-card {
      background: var(--card);
      border: 2px solid rgba(255, 255, 255, 0.96);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(14px);
    }

    .hero {
      text-align: center;
      padding: 52px 28px 44px;
      overflow: hidden;
      position: relative;
    }

    .hero::before,
    .hero::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      filter: blur(2px);
      opacity: 0.6;
    }

    .hero::before {
      width: 170px;
      height: 170px;
      background: #ffe1ef;
      top: -60px;
      left: -45px;
    }

    .hero::after {
      width: 150px;
      height: 150px;
      background: #deefff;
      right: -50px;
      bottom: -55px;
    }

    .mini-label {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 15px;
      border-radius: 999px;
      background: #fff;
      color: #7b66c8;
      font-weight: 800;
      font-size: 14px;
      box-shadow: 0 8px 18px rgba(99, 81, 146, 0.11);
      position: relative;
      z-index: 1;
    }

    h1 {
      margin: 22px 0 15px;
      font-size: clamp(34px, 6vw, 64px);
      line-height: 1.12;
      letter-spacing: -0.055em;
      position: relative;
      z-index: 1;
    }

    .gradient-text {
      background: linear-gradient(90deg, var(--pink), var(--purple), var(--blue));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero p {
      margin: 0 auto;
      max-width: 610px;
      color: var(--muted);
      font-size: clamp(16px, 2vw, 19px);
      line-height: 1.75;
      word-break: keep-all;
      position: relative;
      z-index: 1;
    }

    .hero-icons {
      margin: 28px 0 30px;
      font-size: clamp(34px, 6vw, 52px);
      letter-spacing: 5px;
      position: relative;
      z-index: 1;
    }

    .primary-btn,
    .secondary-btn {
      border: 0;
      border-radius: 18px;
      cursor: pointer;
      font-weight: 900;
      transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

    .primary-btn {
      padding: 17px 28px;
      color: #fff;
      background: linear-gradient(135deg, var(--pink), var(--purple));
      box-shadow: 0 12px 25px rgba(154, 124, 255, 0.3);
      font-size: 18px;
    }

    .secondary-btn {
      padding: 14px 22px;
      color: #6e5bb0;
      background: #f4efff;
      font-size: 16px;
    }

    .primary-btn:hover,
    .secondary-btn:hover,
    .answer-btn:hover {
      transform: translateY(-3px);
    }

    .primary-btn:active,
    .secondary-btn:active,
    .answer-btn:active {
      transform: scale(0.98);
    }

    .notice {
      margin-top: 20px;
      color: #9992a8;
      font-size: 13px;
      position: relative;
      z-index: 1;
    }

    .quiz-wrap {
      display: grid;
      gap: 18px;
    }

    .progress-panel {
      background: rgba(255, 255, 255, 0.78);
      padding: 16px 18px;
      border-radius: 20px;
      box-shadow: 0 10px 26px rgba(90, 71, 138, 0.1);
    }

    .progress-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 10px;
      color: var(--muted);
      font-weight: 800;
      font-size: 14px;
    }

    .progress-bar {
      height: 13px;
      background: #ede9f6;
      border-radius: 999px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--pink), var(--yellow), var(--green), var(--blue));
      transition: width 0.35s ease;
    }

    .quiz-card {
      padding: clamp(24px, 5vw, 46px);
      text-align: center;
    }

    .question-emoji {
      font-size: 58px;
      margin-bottom: 12px;
      animation: wiggle 1.8s ease-in-out infinite;
    }

    @keyframes wiggle {
      0%, 100% { transform: rotate(-3deg) scale(1); }
      50% { transform: rotate(3deg) scale(1.05); }
    }

    .question-number {
      color: #8d7dc7;
      font-weight: 900;
      font-size: 14px;
      letter-spacing: 0.06em;
    }

    .question-title {
      margin: 13px auto 28px;
      max-width: 690px;
      font-size: clamp(22px, 3.5vw, 31px);
      line-height: 1.45;
      letter-spacing: -0.035em;
      word-break: keep-all;
    }

    .answers {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .answer-btn {
      min-height: 145px;
      border: 2px solid transparent;
      border-radius: 23px;
      padding: 22px 18px;
      cursor: pointer;
      text-align: left;
      color: var(--text);
      background: linear-gradient(#fff, #fff) padding-box,
                  linear-gradient(135deg, #ffd4e7, #d9d0ff, #cfe9ff) border-box;
      box-shadow: 0 10px 22px rgba(78, 63, 122, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .answer-btn:hover {
      box-shadow: 0 16px 28px rgba(78, 63, 122, 0.14);
    }

    .answer-emoji {
      display: block;
      font-size: 34px;
      margin-bottom: 11px;
    }

    .answer-text {
      display: block;
      font-weight: 800;
      line-height: 1.55;
      font-size: 16px;
      word-break: keep-all;
    }

    .result-card {
      padding: clamp(26px, 5vw, 48px);
      text-align: center;
      overflow: hidden;
      position: relative;
    }

    .confetti {
      font-size: 27px;
      letter-spacing: 5px;
      margin-bottom: 10px;
    }

    .result-label {
      color: #8b79ca;
      font-weight: 900;
      font-size: 15px;
    }

    .result-type {
      margin: 10px 0 2px;
      font-size: clamp(52px, 10vw, 88px);
      letter-spacing: 0.04em;
      line-height: 1;
      background: linear-gradient(90deg, var(--pink), var(--purple), var(--blue));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .result-name {
      margin: 12px 0 10px;
      font-size: clamp(23px, 4vw, 34px);
      letter-spacing: -0.04em;
    }

    .result-summary {
      max-width: 650px;
      margin: 0 auto 25px;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.75;
      word-break: keep-all;
    }

    .result-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin: 26px 0;
      text-align: left;
    }

    .result-box {
      padding: 20px;
      border-radius: 20px;
      background: #fff;
      box-shadow: 0 9px 18px rgba(83, 67, 127, 0.08);
    }

    .result-box h3 {
      margin: 0 0 10px;
      font-size: 16px;
    }

    .result-box p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      font-size: 15px;
      word-break: keep-all;
    }

    .traits {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 9px;
      margin: 10px 0 28px;
    }

    .trait {
      padding: 9px 13px;
      border-radius: 999px;
      background: #f4f0ff;
      color: #6f5cb4;
      font-weight: 800;
      font-size: 14px;
    }

    .score-area {
      margin: 28px auto;
      max-width: 650px;
      text-align: left;
      padding: 22px;
      background: rgba(248, 246, 255, 0.9);
      border-radius: 22px;
    }

    .score-row {
      margin-bottom: 16px;
    }

    .score-row:last-child {
      margin-bottom: 0;
    }

    .score-labels {
      display: flex;
      justify-content: space-between;
      font-weight: 900;
      font-size: 14px;
      margin-bottom: 7px;
    }

    .score-track {
      display: flex;
      height: 12px;
      overflow: hidden;
      border-radius: 999px;
      background: #e8e3f2;
    }

    .score-left {
      background: linear-gradient(90deg, #ff91bf, #aa8cff);
    }

    .score-right {
      background: linear-gradient(90deg, #79c5ff, #72dbb0);
    }

    .button-group {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 24px;
      transform: translateX(-50%) translateY(30px);
      background: #493f64;
      color: #fff;
      padding: 12px 18px;
      border-radius: 999px;
      font-weight: 800;
      opacity: 0;
      pointer-events: none;
      transition: 0.3s ease;
      z-index: 20;
      white-space: nowrap;
      max-width: calc(100% - 30px);
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .footer {
      text-align: center;
      margin-top: 20px;
      color: #918a9e;
      font-size: 13px;
    }

    @media (max-width: 680px) {
      .app {
        width: min(100% - 18px, 920px);
        padding-top: 18px;
      }

      .hero {
        padding: 42px 20px 36px;
      }

      .answers,
      .result-grid {
        grid-template-columns: 1fr;
      }

      .answer-btn {
        min-height: 118px;
      }

      .floating-emoji {
        opacity: 0.25;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <span class="floating-emoji e1">📚</span>
  <span class="floating-emoji e2">🌈</span>
  <span class="floating-emoji e3">✏️</span>
  <span class="floating-emoji e4">🧸</span>
  <span class="floating-emoji e5">🍀</span>
  <span class="floating-emoji e6">💖</span>

  <main class="app">
    <section id="startScreen" class="screen active">
      <div class="hero">
        <div class="mini-label">🏫 SCHOOL LIFE MBTI TEST ✨</div>
        <h1>
          학교생활로 알아보는<br />
          <span class="gradient-text">나의 MBTI</span>
        </h1>
        <p>
          쉬는 시간, 모둠 활동, 수행평가, 축제 준비까지! 🎒<br />
          학교에서 나는 어떤 모습일까? 12가지 상황을 선택해 알아보세요 💭
        </p>
        <div class="hero-icons">👩‍🏫 🏃‍♀️ 💬 📝 🎨 🎧</div>
        <button class="primary-btn" id="startBtn">테스트 시작하기 🚀</button>
        <div class="notice">※ 재미로 즐기는 간단한 성향 테스트예요! 🥰</div>
      </div>
    </section>

    <section id="quizScreen" class="screen">
      <div class="quiz-wrap">
        <div class="progress-panel">
          <div class="progress-top">
            <span id="progressText">1 / 12</span>
            <span id="progressPercent">8%</span>
          </div>
          <div class="progress-bar" aria-label="진행률">
            <div class="progress-fill" id="progressFill"></div>
          </div>
        </div>

        <div class="quiz-card">
          <div class="question-emoji" id="questionEmoji">🏫</div>
          <div class="question-number" id="questionNumber">QUESTION 01</div>
          <h2 class="question-title" id="questionTitle"></h2>
          <div class="answers" id="answers"></div>
        </div>
      </div>
    </section>

    <section id="resultScreen" class="screen">
      <div class="result-card">
        <div class="confetti">🎉 ✨ 💖 🌈 ✨ 🎉</div>
        <div class="result-label">학교생활 속 나의 MBTI는?</div>
        <h2 class="result-type" id="resultType">ENFP</h2>
        <h3 class="result-name" id="resultName"></h3>
        <p class="result-summary" id="resultSummary"></p>

        <div class="traits" id="traits"></div>

        <div class="result-grid">
          <div class="result-box">
            <h3>🏫 학교에서의 모습</h3>
            <p id="schoolStyle"></p>
          </div>
          <div class="result-box">
            <h3>🤝 찰떡 모둠 역할</h3>
            <p id="teamRole"></p>
          </div>
          <div class="result-box">
            <h3>💪 숨은 강점</h3>
            <p id="strength"></p>
          </div>
          <div class="result-box">
            <h3>💌 한마디 조언</h3>
            <p id="tip"></p>
          </div>
        </div>

        <div class="score-area" id="scoreArea"></div>

        <div class="button-group">
          <button class="primary-btn" id="shareBtn">결과 공유하기 📤</button>
          <button class="secondary-btn" id="restartBtn">다시 해보기 🔄</button>
        </div>
      </div>
    </section>

    <div class="footer">Made with 💖 for fun school days 🏫</div>
  </main>

  <div class="toast" id="toast">결과가 복사되었어요! 📋✨</div>

  <script>
    const questions = [
      {
        emoji: "⏰",
        text: "등교해서 교실에 들어갔을 때 나는?",
        options: [
          { emoji: "👋", text: "친구들에게 먼저 인사하고 오늘 있었던 일을 이야기한다!", type: "E" },
          { emoji: "🎧", text: "조용히 자리에 앉아 준비물을 정리하며 하루를 시작한다.", type: "I" }
        ]
      },
      {
        emoji: "🍙",
        text: "점심시간에 급식실로 이동할 때 나는?",
        options: [
