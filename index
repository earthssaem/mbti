    const dimensions = [
      ["E", "I"],
      ["S", "N"],
      ["T", "F"],
      ["J", "P"]
    ];

    const startScreen = document.getElementById("startScreen");
    const quizScreen = document.getElementById("quizScreen");
    const resultScreen = document.getElementById("resultScreen");
    const startBtn = document.getElementById("startBtn");
    const restartBtn = document.getElementById("restartBtn");
    const shareBtn = document.getElementById("shareBtn");
    const answersEl = document.getElementById("answers");
    const toast = document.getElementById("toast");

    let currentQuestion = 0;
    let scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };
    let latestType = "";

    function switchScreen(target) {
      [startScreen, quizScreen, resultScreen].forEach(screen => screen.classList.remove("active"));
      target.classList.add("active");
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function startQuiz() {
      currentQuestion = 0;
      scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };
      switchScreen(quizScreen);
      renderQuestion();
    }

    function renderQuestion() {
      const q = questions[currentQuestion];
      const progress = Math.round(((currentQuestion + 1) / questions.length) * 100);

      document.getElementById("questionEmoji").textContent = q.emoji;
      document.getElementById("questionNumber").textContent = `QUESTION ${String(currentQuestion + 1).padStart(2, "0")}`;
      document.getElementById("questionTitle").textContent = q.text;
      document.getElementById("progressText").textContent = `${currentQuestion + 1} / ${questions.length}`;
      document.getElementById("progressPercent").textContent = `${progress}%`;
      document.getElementById("progressFill").style.width = `${progress}%`;

      answersEl.innerHTML = "";

      q.options.forEach(option => {
        const button = document.createElement("button");
        button.className = "answer-btn";
        button.innerHTML = `
          <span class="answer-emoji">${option.emoji}</span>
          <span class="answer-text">${option.text}</span>
        `;
        button.addEventListener("click", () => chooseAnswer(option.type));
        answersEl.appendChild(button);
      });
    }

    function chooseAnswer(type) {
      scores[type] += 1;
      currentQuestion += 1;

      if (currentQuestion < questions.length) {
        renderQuestion();
      } else {
        showResult();
      }
    }

    function getResultType() {
      return dimensions.map(([a, b]) => scores[a] >= scores[b] ? a : b).join("");
    }

    function createScoreRows() {
      return dimensions.map(([left, right]) => {
        const total = scores[left] + scores[right];
        const leftPercent = Math.round((scores[left] / total) * 100);
        const rightPercent = 100 - leftPercent;

        return `
          <div class="score-row">
            <div class="score-labels">
              <span>${left} ${leftPercent}%</span>
              <span>${right} ${rightPercent}%</span>
            </div>
            <div class="score-track">
              <div class="score-left" style="width:${leftPercent}%"></div>
              <div class="score-right" style="width:${rightPercent}%"></div>
            </div>
          </div>
        `;
      }).join("");
    }

    function showResult() {
      latestType = getResultType();
      const data = resultData[latestType];

      document.getElementById("resultType").textContent = latestType;
      document.getElementById("resultName").textContent = data.name;
      document.getElementById("resultSummary").textContent = data.summary;
      document.getElementById("schoolStyle").textContent = data.school;
      document.getElementById("teamRole").textContent = data.role;
      document.getElementById("strength").textContent = data.strength;
      document.getElementById("tip").textContent = data.tip;
      document.getElementById("traits").innerHTML = data.traits
        .map(trait => `<span class="trait"># ${trait}</span>`)
        .join("");
      document.getElementById("scoreArea").innerHTML = createScoreRows();

      switchScreen(resultScreen);
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 2200);
    }

    async function shareResult() {
      const data = resultData[latestType];
      const shareText = `🏫 학교생활 MBTI 결과\n나는 ${latestType}, ${data.name}\n${data.summary}`;

      if (navigator.share) {
        try {
          await navigator.share({
            title: "학교생활로 알아보는 MBTI",
            text: shareText
          });
          return;
        } catch (error) {
          if (error.name === "AbortError") return;
        }
      }

      try {
        await navigator.clipboard.writeText(shareText);
        showToast("결과가 복사되었어요! 📋✨");
      } catch (error) {
        showToast("복사하지 못했어요. 화면을 캡처해 주세요! 📸");
      }
    }

    startBtn.addEventListener("click", startQuiz);
    restartBtn.addEventListener("click", startQuiz);
    shareBtn.addEventListener("click", shareResult);
  </script>
</body>
</html>
