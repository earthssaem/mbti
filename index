      },
      {
        emoji: "🔬",
        text: "새로운 과학 탐구 주제를 정할 때 더 끌리는 것은?",
        options: [
          { emoji: "🔎", text: "관찰하거나 측정할 수 있는 구체적이고 현실적인 주제", type: "S" },
          { emoji: "🌌", text: "상상력을 펼칠 수 있는 새롭고 독특한 주제", type: "N" }
